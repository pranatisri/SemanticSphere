# Optional configuration overrides (defaults are in core/config.py)
#
# Usage:
# - Copy this file to a real env file, e.g. `.env` (if your environment allows dotfiles),
#   or export the variables in your shell.
# - The project loads env vars via python-dotenv in `core/config.py`.

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Fuzzy clustering
N_CLUSTERS=20
FUZZINESS_M=2.0
# Used to justify K choice (silhouette sweep). Comma-separated ints.
CLUSTERING_K_SWEEP=10,15,20,25

# Search + cache
TOP_K_RESULTS=5
DEFAULT_SIMILARITY_THRESHOLD=0.85

